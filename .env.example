# ===== App =====
APP_ENV=dev
LOG_LEVEL=INFO

# ===== PostgreSQL =====
DATABASE_URL=postgresql://da10:da10@localhost:5432/da10

# ===== Embedding provider =====
# OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=BAAI/bge-m3

# ===== Vector store (Qdrant) =====
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=vsf_travel

# ===== Keyword search (OpenSearch) =====
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX=vsf_travel
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=changeme
BM25_INDEX=vsf_hotels_bm25_current
BM25_TARGET_INDEX=vsf_hotels_bm25_v1_0_0
BM25_ALIAS=vsf_hotels_bm25_current
BM25_PROMOTE_ALIAS=false
CLEANED_DATA_DIR=data/cleaned
BULK_CHUNK_SIZE=25
BULK_MAX_CHUNK_BYTES=2097152

# ===== Retrieval defaults =====
HYBRID_TOP_K=20
RERANK_TOP_K=5
TOKEN_BUDGET=4000

# ===== LLM cho ABSA (KE Sprint 2 Bước 5) — đa-provider, team chọn tùy ý =====
# Provider: openai | gemini | ollama | claude. Đổi provider KHÔNG sửa code.
LLM_PROVIDER=openai
# Model (bỏ trống = mặc định): openai->gpt-4o-mini | gemini->gemini-1.5-flash
#   | ollama->qwen2.5 | claude->claude-haiku-4-5-20251001
LLM_MODEL=gpt-4o-mini
# Chỉ cần điền key của provider đang dùng:
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...
# ANTHROPIC_API_KEY=...
# OLLAMA_HOST=http://localhost:11434   # chạy offline, miễn phí
