# ===== Data =====
# data/raw is committed so the team can see crawled source data
# cleaned data is committed for downstream consumption; processed are derived outputs
data/processed/*
!data/**/.gitkeep
!data/samples/
# keep small samples committed; ignore everything else under samples that is large
data/samples/*.parquet

# ===== Model / index artifacts =====
*.bin
# Qdrant vector index graph files — needed for the teammate to not re-embed
!.docker_volumes/qdrant_storage/**/*.bin
*.pt
*.ckpt
*.faiss
*.index
indexing/**/*.index
embeddings/

# ===== Vector store / search engine local volumes =====
elasticsearch_data/
# OpenSearch data — regenerated by container, teammate rebuilds BM25 (~520 docs, fast)
.docker_volumes/opensearch_data/

# Qdrant runtime artifacts không cần commit (snapshot binary lớn; thư mục backup tạm khi cứu storage)
.docker_volumes/qdrant_storage/snapshots/
.qdrant_segment_backup/
.qdrant_wal_backup/
# checkpoint resume của qdrant_index — riêng từng máy, không commit
data/qdrant_index_checkpoint.json

