   "type": "stat",
   "gridPos": {
    "h": 4,
    "w": 6,
    "x": 0,
    "y": 16
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "expr": "rate(da10_search_zero_results_total[5m])",
     "legendFormat": "zero-result/s",
     "refId": "A"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "reqps",
     "thresholds": {
      "steps": [
       {
        "color": "green",
        "value": null
       },
       {
        "color": "yellow",
