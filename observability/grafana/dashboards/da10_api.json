  {
   "id": 1,
   "title": "Search p95 Latency (server-side)",
   "type": "timeseries",
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 0,
    "y": 0
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "expr": "histogram_quantile(0.95, rate(da10_http_request_duration_seconds_bucket{endpoint=\"/search\"}[5m])) * 1000",
     "legendFormat": "p95 ms",
     "refId": "A"
    },
    {
     "expr": "histogram_quantile(0.50, rate(da10_http_request_duration_seconds_bucket{endpoint=\"/search\"}[5m])) * 1000",
     "legendFormat": "p50 ms",
     "refId": "B"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "ms",
     "custom": {
      "lineWidth": 2
     },
     "thresholds": {
      "steps": [
       {
        "color": "green",
        "value": null
       },
       {
        "color": "red",
        "value": 500
       }
      ]
     }
    },
    "overrides": []
   },
   "options": {
    "tooltip": {
     "mode": "multi"
    }
   }
  },
