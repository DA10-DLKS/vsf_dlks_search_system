  {
   "id": 3,
   "title": "Request Rate (req/s)",
   "type": "timeseries",
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 0,
    "y": 8
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "expr": "rate(da10_http_requests_total{endpoint=\"/search\"}[5m])",
     "legendFormat": "/search",
     "refId": "A"
    },
    {
     "expr": "rate(da10_http_requests_total{endpoint=\"/context\"}[5m])",
     "legendFormat": "/context",
     "refId": "B"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "reqps"
    },
    "overrides": []
   }
  },
  {
   "id": 4,
   "title": "Error Rate (5xx req/s)",
   "type": "timeseries",
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 12,
    "y": 8
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "expr": "rate(da10_http_requests_total{status=~\"5..\"}[5m])",
     "legendFormat": "5xx {{endpoint}}",
     "refId": "A"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "reqps",
     "custom": {
      "lineWidth": 2
     },
